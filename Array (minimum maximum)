#include<stdio.h>
int main()
{
	int arr[5],i;
	printf("Random values are ");
	for (int i=0;i<5;i++)
	{
		scanf("%d",&arr[i]);
	}
	int max= arr[0];
	int min=arr[0];
	
	for(int i=0;i<5;i++)
	{
	 
	 if (arr[i]>max)
	{
		max=arr[i];
	}
	
	
	if (arr[i]<min)
	{
		min=arr[i];
	}
	}
	printf("max %d",max);
	printf("\nmin%d",min);
	
	return 0;
}
