#include<stdio.h>
int main() {
    int n, i, j;
    printf("Total number of arr ");
    scanf(" %d", &n);
    int arr[n], visited[n];

    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
        visited[i] = 0;
    }

    for(i = 0; i < n; i++) {
        if(visited[i] == 1) continue;

        int count = 1;
        for(j = i+1; j < n; j++) {
            if(arr[i] == arr[j]) {
                visited[j] = 1;
                count++;
            }
        }

        printf("we see that %d is   %d times👀\n", arr[i], count);
    }
}
